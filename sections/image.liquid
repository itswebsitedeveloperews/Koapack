{% schema %}
{
  "name": "Centered Image Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Upload Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt Text",
      "default": "Centered Image"
    }
  ],
  "presets": [
    {
      "name": "Centered Image Section"
    }
  ]
}
{% endschema %}

<div class="centered-image-wrapper">
  {% if section.settings.center_image %}
    <img
      src="{{ section.settings.center_image | img_url: '720x' }}"
      alt="{{ section.settings.alt_text }}"
      class="centered-image"
      width="800"
      height="500"
    >
  {% endif %}
</div>

<style>
.centered-image-wrapper {
  display: flex;
  justify-content: center;
  align-items: center; /* Use this for vertical centering */
  padding: 0 20px;
  background-color: #FFFFFF; /* Optional background */
}
.centered-image {
  max-width: 100%;
  height: 50rem;
  width: 90rem;
  display: block;
}

@media screen and (max-width: 749px) {
  .centered-image {
  height: 30rem;
  width: 70rem;
}
}
</style>
