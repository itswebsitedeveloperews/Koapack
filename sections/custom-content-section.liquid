{{ 'section-custom-content-section.css' | asset_url | stylesheet_tag }}

<div class="custom-content-section">
  <h1 class="custom-content-section__heading">
    {{ section.settings.heading }}
  </h1>

  <div class="custom-content-section__text">
    {{ section.settings.text }}
  </div>

  {% if section.settings.button_label != blank %}
    <a href="{{ section.settings.button_link }}" class="custom-content-section__button">
      {{ section.settings.button_label }}
    </a>
  {% endif %}

  {% if section.settings.image != blank %}
    <div class="custom-content-section__image-wrapper" style="max-width: 100%; overflow: hidden;">
      {{
        section.settings.image
        | image_url: width: section.settings.image_width
        | image_tag:
          loading: 'lazy',
          widths: '400, 600, 800, 1100',
          width: section.settings.image_width,
          class: 'responsive-image',
          alt: section.settings.image.alt | escape
      }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom Content Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You've just found your last packaging partner"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Design & order sustainable packaging solutions your brand will love.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Our Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image Width",
      "options": [
        { "value": "400", "label": "Small (400px)" },
        { "value": "600", "label": "Medium (600px)" },
        { "value": "800", "label": "Large (800px)" },
        { "value": "1100", "label": "Full width (1100px)" }
      ],
      "default": "1100"
    }
  ],
  "presets": [
    {
      "name": "Custom Content Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
