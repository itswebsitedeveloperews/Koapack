{% style %}
  #shopify-section-{{ section.id }} {
    background: linear-gradient(to bottom, #F5F1E8 73%, #FFFFFF 27%);
    padding: 60px 0 80px;
  }

  .image-carousel {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .carousel-title {
    font-family: 'Instrument Serif', sans-serif;
    font-size: 40px;
    color: #6D8EA1;
    text-align: center;
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-family: 'Roboto', sans-serif;
    font-weight: 400px;
    font-size: 32px;
    color: #3E5D49;
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
    letter-spacing: -0.4px;
    line-height: 100%;
  }

  .section-subtitle i {
    font-family: 'Instrument Serif', serif;
    font-weight: 400px;
    font-size: 40px;
    font-style: italic;
    color: #3E5D49;
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
    letter-spacing: -0.4px;
     line-height: 100%;
  }

  .image-carousel__button {
    font-family: 'Roboto', sans-serif;
    border: 1px solid #BE7A58;
    background: none;
    color: #C17A5C;
    text-decoration: none;
    font-size: 16px;
    padding: 12px 24px;
    transition: all 0.3s ease;
    display: block;
    margin: 0 auto 60px;
    width: fit-content;
    cursor: pointer;
    line-height: 1.1;
    letter-spacing: -0.4px;
  }

  .image-carouse__button:hover {
    background-color: #C17A5C;
    color: #fff;
  }

  .carousel-container {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-container::-webkit-scrollbar {
    display: none;
  }

  .carousel-item {
    scroll-snap-align: start;
    flex: 0 0 calc(33.333% - 14px);
    min-width: 300px;
    position: relative;
  }

  .carousel-item__image-container {
    width: 100%;
    height: 380px;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background-color: #FFFFFF;
  }

  .carousel-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1;
    border: none;
    font-size: 24px;
    color: #000;
  }

  .carousel-arrow.prev {
    left: 0;
  }

  .carousel-arrow.next {
    right: 0;
  }

  @media (max-width: 1024px) {
    .carousel-item {
      flex: 0 0 calc(50% - 10px);
    }
  }

  @media (max-width: 768px) {
    .image-carousel {
      padding: 0 20px;
    }
    
    .carousel-title {
      font-size: 32px;
    }
    
    .section-subtitle,
    .section-subtitle i{
      font-size: 18px;
    }
    
    .carousel-container {
      gap: 10px;
    }
    
    .carousel-item {
      flex: 0 0 100%;
    }
    
    .carousel-item__image-container {
      height: 320px;
    }
    
    .carousel-arrow {
      width: 30px;
      height: 30px;
      font-size: 18px;
    }
  }
{% endstyle %}

<div class="image-carousel">
  <p class="section-subtitle">We craft purposeful packaging that <i>empowers women, honors the planet, and leaves nothing to waste.</i> Whether it's a tote, a potli, or a handmade detail — every piece is a reflection of care, intention, and the quiet power of choosing better.</p>
  
  {% if section.settings.button_link != blank %}
  <a href="{{ section.settings.button_link }}" class="image-carousel__button">Explore Our Products</a>
  {% else %}
  <button class="image-carousel__button" disabled>Explore Our Products</button>
  {% endif %}

  
  <div class="carousel-wrapper">
    <!-- <button class="carousel-arrow prev">←</button> -->
    
    <div class="carousel-container" id="carousel">
      {% for i in (1..3) %}
        {% assign image_key = 'image_' | append: i %}
        <div class="carousel-item">
          <div class="carousel-item__image-container">
            {% if section.settings[image_key] != blank %}
              <img 
                src="{{ section.settings[image_key] | img_url: '800x' }}" 
                alt="Carousel image {{ i }}"
                class="carousel-item__image"
                width="800"
                height="600"
                loading="lazy"
              >
            {% else %}
              <div style="width: 100%; height: 100%; background: #eee; display: flex; align-items: center; justify-content: center;">
                <span>Image {{ i }}</span>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    
    <!-- <button class="carousel-arrow next">→</button> -->
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const carousel = document.getElementById('carousel');
    const prevBtn = document.querySelector('.prev');
    const nextBtn = document.querySelector('.next');
    const items = document.querySelectorAll('.carousel-item');
    let currentIndex = 0;
    let itemsToShow = window.innerWidth < 768 ? 1 : window.innerWidth < 1024 ? 2 : 3;
    
    function updateCarousel() {
      const gap = window.innerWidth < 768 ? 10 : 20;
      const itemWidth = items[0].offsetWidth + gap;
      carousel.scrollTo({
        left: currentIndex * itemWidth,
        behavior: 'smooth'
      });
      
      if (prevBtn && nextBtn) {
        prevBtn.style.display = currentIndex === 0 ? 'none' : 'flex';
        nextBtn.style.display = currentIndex >= items.length - itemsToShow ? 'none' : 'flex';
      }
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        if (currentIndex > 0) {
          currentIndex--;
          updateCarousel();
        }
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        if (currentIndex < items.length - itemsToShow) {
          currentIndex++;
          updateCarousel();
        }
      });
    }
    
    updateCarousel();
    
    window.addEventListener('resize', function() {
      const newItemsToShow = window.innerWidth < 768 ? 1 : window.innerWidth < 1024 ? 2 : 3;
      if (newItemsToShow !== itemsToShow) {
        itemsToShow = newItemsToShow;
        currentIndex = Math.min(currentIndex, items.length - itemsToShow);
        updateCarousel();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Image Carousel",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1",
      "info": "Recommended size: 800x600px"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2",
      "info": "Recommended size: 800x600px"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3",
      "info": "Recommended size: 800x600px"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Select a page, collection, or product to link the button to."
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "category": "Custom"
    }
  ]
}
{% endschema %}