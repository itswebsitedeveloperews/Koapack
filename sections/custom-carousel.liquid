{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .custom-carousel-{{ section.id }} {
    position: relative;
    max-width: 100%;
    overflow: hidden;
  }

  .custom-carousel__header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.heading_spacing }}px;
    color: {{ section.settings.heading_color }};
  }

  .custom-carousel__header h2 {
    font-size: {{ section.settings.heading_size }}px;
    margin-bottom: {{ section.settings.heading_subheading_spacing }}px;
    color: inherit;
    font-family: 'Roboto', sans-serif;
    line-height: 1.2;
  }

  .custom-carousel__header p {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0;
    letter-spacing: -0.02px;
    font-family: 'Roboto', sans-serif;
    line-height: 1.4;
    margin-bottom: 3rem;
  }

  .custom-carousel__slides {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: {{ section.settings.slide_gap }}px;
    padding-bottom: 20px;
  }

  .custom-carousel__slides::-webkit-scrollbar {
    display: none;
  }

  .custom-carousel__slide {
    scroll-snap-align: start;
    flex-shrink: 0;
    position: relative;
    display: flex;
    background: {{ section.settings.slide_bg_color }};
    border-radius: 12px;
    width: calc(100% / {{ section.settings.visible_slides }});
    max-width: 900px;
    min-height: {{ section.settings.slide_height }}px;
    flex-direction: row;
  }

  .testimonial-image-container {
    width: 50%;
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: 12px 0 0 12px;
  }

  .testimonial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-content {
    width: 50%;
    padding: 3rem;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .testimonial-logo {
    max-width: 150px;
    height: auto;
    max-height: 60px;
    object-fit: contain;
    margin-bottom: 2rem;
  }

  .testimonial-text {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 2rem;
    margin-top: 8rem;
    color: {{ section.settings.text_color }};
    font-family: 'Roboto', sans-serif;
    letter-spacing: -0.48px;
    font-weight: 400;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
  }

  .author-image {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-info {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-size: 16px;
    margin-bottom: 0.2rem;
    color: {{ section.settings.text_color }};
    font-family: 'Roboto', sans-serif;
    letter-spacing: -0.48px;
    font-weight: 500;
    line-height: 1.3;
  }

  .author-title {
    font-size: 12px;
    color: #C17A5C;
    font-family: 'Roboto', sans-serif;
    letter-spacing: -0.36px;
    font-weight: 400;
    line-height: 1.3;
  }

  .custom-carousel__navigation {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    position: absolute;
    top: 60px;
    right: 0;
    z-index: 2;
  }

  .custom-carousel__nav-button {
    background: {{ section.settings.nav_button_bg }};
    color: {{ section.settings.nav_button_color }};
    border: 2px solid {{ section.settings.nav_button_border_color }};
    border-radius: 50%;
    width: {{ section.settings.nav_button_size }}px;
    height: {{ section.settings.nav_button_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 0 0 2px #fff;
    transition: all 0.3s ease;
    color: #6D8EA1;
  border: 1px solid #6D8EA1;
  background: transparent;
  }

  .custom-carousel__pagination {
    display: flex;
    gap: 0.5rem;
    margin: 0 1rem;
    font-family: 'Roboto', sans-serif;
    font-size: 16px;
    color: {{ section.settings.text_color }};
    gap: 1.5rem;
  margin: 0 1.5rem;
  }
.pagination-number {
  color: #C4D1D9;
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s ease;
}

.pagination-number.active {
  color: #6D8EA1;
  border-color: #6D8EA1;
  font-weight: bold;
}
  .icon-arrow-right,
  .icon-arrow-left {
    display: inline-block;
    width: 16px;
    height: 16px;
  }

  .icon-arrow-right svg,
  .icon-arrow-left svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
 @media screen and (max-width: 1024px) {
   .custom-carousel__navigation {  
    top: 100px;
   }
 }
  @media screen and (max-width: 749px) {
    .custom-carousel__header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .custom-carousel__header h2 {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: 0.5rem;
    }

    .custom-carousel__header p {
      font-size: {{ section.settings.subheading_size_mobile }}px;
      margin-bottom: 2rem;
    }

    .custom-carousel__slide {
      width: calc(100% / {{ section.settings.visible_slides_mobile }});
      min-height: auto;
      flex-direction: column;
      height: auto;
      aspect-ratio: 1/1.4;
    }

    .testimonial-image-container,
    .testimonial-content {
      width: 100%;
    }

    .testimonial-image-container {
      height: 40%;
      border-radius: 12px 12px 0 0;
    }

    .testimonial-content {
      padding: 1.5rem;
      height: 60%;
    }

    .testimonial-logo {
      width: 120px;
      margin-bottom: 1rem;
    }

    .testimonial-text {
      font-size: 14px;
      margin-bottom: 1.5rem;
      margin-top: 0;
    }

    .author-image {
      width: 40px;
      height: 40px;
    }

    .author-name {
      font-size: 14px;
    }

    .author-title {
      font-size: 11px;
    }

     .custom-carousel__navigation {
        top: unset;
        bottom: 0;
        right: unset;
        transform: translateX(-50%);
        left: 50%;
    }
    .custom-carousel__slides {
    margin-bottom: 40px;
}

    .custom-carousel__nav-button {
      width: 36px;
      height: 36px;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="custom-carousel-{{ section.id }}">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="custom-carousel__header">
        {%- if section.settings.heading != blank -%}
         <h2 class="h1">{{ section.settings.heading | replace: "Lasting Impression", "<em>Lasting Impression</em>" }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="sh2">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="custom-carousel__navigation">
      <button class="custom-carousel__nav-button" aria-label="Previous slide">
        <span class="icon-arrow-left">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/>
          </svg>
        </span>
      </button>
      
      <div class="custom-carousel__pagination">
        {%- for block in section.blocks -%}
          <span class="pagination-number" data-index="{{ forloop.index0 }}">{{ forloop.index }}</span>
        {%- endfor -%}
      </div>
      
      <button class="custom-carousel__nav-button" aria-label="Next slide">
        <span class="icon-arrow-right">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </span>
      </button>
    </div>

    <div class="custom-carousel__slides" id="carousel-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="custom-carousel__slide" {{ block.shopify_attributes }}>
          <div class="testimonial-content">
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: width: auto | image_tag:
                loading: 'lazy',
                class: 'testimonial-logo',
                alt: block.settings.logo.alt | escape
              }}
            {%- endif -%}
            
            {%- if block.settings.testimonial != blank -%}
              <div class="testimonial-text">{{ block.settings.testimonial }}</div>
            {%- endif -%}
            
            <div class="testimonial-author">
              {%- if block.settings.author_image != blank -%}
                {{ block.settings.author_image | image_url: width: 70 | image_tag:
                  loading: 'lazy',
                  class: 'author-image',
                  alt: block.settings.author_name | escape
                }}
              {%- else -%}
                <div class="author-image" style="background: #eee;"></div>
              {%- endif -%}
              
              <div class="author-info">
                {%- if block.settings.author_name != blank -%}
                  <div class="author-name">{{ block.settings.author_name }}</div>
                {%- endif -%}
                {%- if block.settings.author_title != blank -%}
                  <div class="author-title">{{ block.settings.author_title }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
          <div class="testimonial-image-container">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                class: 'testimonial-image',
                alt: block.settings.image.alt | escape
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'testimonial-image placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const carousel = document.getElementById('carousel-{{ section.id }}');
    const prevBtn = carousel?.closest('.custom-carousel-{{ section.id }}').querySelector('.custom-carousel__nav-button:first-child');
    const nextBtn = carousel?.closest('.custom-carousel-{{ section.id }}').querySelector('.custom-carousel__nav-button:last-child');
    const paginationNumbers = document.querySelectorAll('.pagination-number');
    
    if (!carousel) return;
    
    const updateCarousel = () => {
      const slideWidth = carousel.querySelector('.custom-carousel__slide')?.offsetWidth || 0;
      const gap = parseInt('{{ section.settings.slide_gap }}');
      return slideWidth + gap;
    };
    
    let scrollAmount = updateCarousel();
    
    window.addEventListener('resize', () => {
      scrollAmount = updateCarousel();
    });
    
    const updatePagination = () => {
      const scrollPosition = carousel.scrollLeft;
      const slideWidth = carousel.querySelector('.custom-carousel__slide')?.offsetWidth || 0;
      const gap = parseInt('{{ section.settings.slide_gap }}');
      const totalWidth = slideWidth + gap;
      
      const currentSlide = Math.round(scrollPosition / totalWidth);
      
      paginationNumbers.forEach((num, index) => {
        if (index === currentSlide) {
          num.style.fontWeight = 'bold';
        } else {
          num.style.fontWeight = 'normal';
        }
      });
    };
    
    carousel.addEventListener('scroll', updatePagination);
    
    prevBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    
    nextBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
    
    // Click handler for pagination numbers
    paginationNumbers.forEach(num => {
      num.addEventListener('click', () => {
        const index = parseInt(num.getAttribute('data-index'));
        const slideWidth = carousel.querySelector('.custom-carousel__slide')?.offsetWidth || 0;
        const gap = parseInt('{{ section.settings.slide_gap }}');
        const scrollTo = index * (slideWidth + gap);
        carousel.scrollTo({ left: scrollTo, behavior: 'smooth' });
      });
    });
    
    // Initialize pagination
    updatePagination();
});
</script>

