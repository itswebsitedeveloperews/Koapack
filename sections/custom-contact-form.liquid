{%- style -%}
  .contact-form-{{ section.id }} {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  
  .contact-form-{{ section.id }} .form-heading {
    font-family: 'Roboto', sans-serif;
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 15px;
    color: {{ section.settings.heading_color }};
    font-size: 28px;
  }
  
  .contact-form-{{ section.id }} .form-subheading {
    font-family: 'Roboto', sans-serif;
    text-align: {{ section.settings.subheading_alignment }};
    margin-bottom: 50px;
    color: {{ section.settings.subheading_color }};
    font-size: 20px;
    letter-spacing: -0.02px;
  }
  
  .contact-form-{{ section.id }} .form-field-label {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 5px;
    color: #3E5D49;
    margin-bottom: 8px;
    display: block;
    line-height: 1.2;
  }
  
  .contact-form-{{ section.id }} .form-row {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
  }
  
  .contact-form-{{ section.id }} .form-field {
    flex: 1;
  }
  
  .contact-form-{{ section.id }} input,
  .contact-form-{{ section.id }} textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #3E5D49;
    font-family: 'Roboto', sans-serif;
  }
  
  .contact-form-{{ section.id }} textarea {
    min-height: 150px;
    resize: vertical;
  }
  
  .contact-form-{{ section.id }} .submit-button {
    font-family: 'Roboto', sans-serif;
    border: 1px solid #3E5D49;
    background: #3E5D49;
    color: #FFFFFF;
    text-decoration: none;
    font-size: 16px;
    padding: 12px 24px;
    transition: all 0.3s ease;
    display: block;
    margin: 0 auto;
    margin-top: 2rem;
    width: 30%;
    cursor: pointer;
    text-align: {{ section.settings.button_alignment }};
    letter-spacing: -0.4px;
    line-height: 1.1;
  }
  
  .contact-form-{{ section.id }} .submit-button:hover {
    opacity: 0.9;
  }
  
  @media (max-width: 749px) {
    .contact-form-{{ section.id }} .form-row {
      flex-direction: column;
      gap: 20px;
    }
    
    .contact-form-{{ section.id }} .submit-button {
      max-width: 100%;
    }
    .contact-form-{{ section.id }} .form-heading {
      font-size: 24px;
    }
    .contact-form-{{ section.id }} .form-subheading {
      font-size: 16px;
      margin-bottom: 20px;
    }
  }
  #shopify-section-template--18379992858795__custom_contact_form_WKYjXL em,
  #shopify-section-template--18379992858795__custom_contact_form_WKYjXL i,
  #shopify-section-template--18408001077419__custom_contact_form_aHDT7y em,
  #shopify-section-template--18408001077419__custom_contact_form_aHDT7y i, 
  #shopify-section-template--18491625177259__custom_contact_form_hD6r4W em,
  #shopify-section-template--18491625177259__custom_contact_form_hD6r4W i {
    font-style: italic !important;
    font-family: 'Instrument Serif', serif;
  }
{%- endstyle -%}



<div class="contact-form-{{ section.id }} page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="form-heading">{{ section.settings.heading | replace: 'Love to Hear', '<em>Love to Hear</em>'}}</h2>
  {%- endif -%}
  
  {%- if section.settings.subheading != blank -%}
    <p class="form-subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}
  
  {% form 'contact' %}
    {% if form.errors %}
      <div class="contact__form-error">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}
    
    {% if form.posted_successfully? %}
      <p class="form-success">Thank you for your message!</p>
    {% endif %}
    
    <div class="form-row">
      <div class="form-field">
        <label for="ContactFormName" class="form-field-label">Your Name</label>
        <input type="text"
          id="ContactFormName"
          name="contact[name]"
          required>
      </div>
      
      <div class="form-field">
        <label for="ContactFormPhone" class="form-field-label">Phone Number</label>
        <input type="tel"
          id="ContactFormPhone"
          name="contact[phone]">
      </div>
    </div>
    
    <div class="form-field">
      <label for="ContactFormMessage" class="form-field-label">Message</label>
      <textarea rows="10"
        id="ContactFormMessage"
        name="contact[body]"
        required></textarea>
    </div>
    
    <button type="submit" class="submit-button">
      {{ section.settings.button_text }}
    </button>
  {% endform %}
</div>

{% schema %}
{
  "name": "Custom Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get in touch with our team"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#666666"
    },
    {
      "type": "select",
      "id": "subheading_alignment",
      "label": "Subheading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Submit"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Custom Contact Form",
      "category": "Contact"
    }
  ]
}
{% endschema %}