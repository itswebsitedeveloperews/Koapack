cat > .gitignore <<'EOF'
# dependencies
node_modules/
**/node_modules/

# build output
build/
**/build/
dist/
**/dist/
.cache/
**/.cache/

# env / secrets
.env
.env.*
!.env.example

# Shopify local files
.shopify/
**/.shopify/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# system/editor
.DS_Store
.vscode/
.idea/
EOF
# Generated files
.react-router/
prisma/dev.sqlite
prisma/dev.sqlite-journal
node_modules/
build/
dist/
